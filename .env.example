# Ethereum mainnet RPC, read-only data collection. Free tier is fine
# (e.g. https://eth.llamarpc.com, or a free Alchemy/Infura endpoint).
MAINNET_RPC_URL=

# Sepolia RPC + deployer key, contract deployment only.
# Never commit the real private key - this file only holds placeholders.
SEPOLIA_RPC_URL=
SEPOLIA_DEPLOYER_PRIVATE_KEY=

# Etherscan v2 unified multichain API key (https://etherscan.io/apis).
# Used for contract verification and gas/usage data.
ETHERSCAN_API_KEY=

# CoinGecko free tier needs no key; leave blank unless you have a demo key.
COINGECKO_API_KEY=
